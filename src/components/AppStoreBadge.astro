---
/**
 * AppStoreBadge — official-styled badge with a graceful "Coming soon" variant.
 *
 * We deliberately avoid the literal Apple App Store badge artwork (which has
 * strict trademark usage rules) for the unlaunched state. When a real Store URL
 * appears in `appStore.url`, we render the official-style typographic badge with
 * a real link; otherwise we render a dashed "Coming soon" placeholder that says
 * the expected quarter.
 */
import type { AppStoreInfo } from '@data/apps';

interface Props {
  store: AppStoreInfo;
  appName: string;
}

const { store, appName } = Astro.props;
const live = Boolean(store.url);
---

{live ? (
  <a class="store-badge live" href={store.url} target="_blank" rel="noopener noreferrer" aria-label={`${appName} on the App Store`}>
    <svg class="apple" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M16.365 1.43c0 1.14-.46 2.23-1.22 3.04-.81.87-2.13 1.55-3.23 1.46-.13-1.11.45-2.27 1.18-3.05.82-.87 2.22-1.5 3.27-1.45zM20.5 17.65c-.58 1.34-1.27 2.66-2.34 3.96-.93 1.13-2.08 2.53-3.5 2.55-1.4.02-1.86-.82-3.46-.82-1.6 0-2.1.8-3.42.84-1.37.04-2.42-1.22-3.36-2.35-1.93-2.32-3.4-6.55-1.42-9.4 1.04-1.48 2.85-2.4 4.85-2.43 1.39-.02 2.7.93 3.43.93.73 0 2.34-1.15 3.95-.98.68.03 2.6.27 3.83 2.05-.1.06-2.29 1.34-2.26 4.0.03 3.1 2.7 4.14 2.73 4.15z" />
    </svg>
    <span class="lf">
      <span class="pre">Download on the</span>
      <span class="post">App Store</span>
    </span>
  </a>
) : (
  <span class="store-badge coming-soon" aria-label={`${appName} — coming soon to the App Store`}>
    <svg class="apple muted" viewBox="0 0 24 24" aria-hidden="true">
      <path fill="currentColor" d="M16.365 1.43c0 1.14-.46 2.23-1.22 3.04-.81.87-2.13 1.55-3.23 1.46-.13-1.11.45-2.27 1.18-3.05.82-.87 2.22-1.5 3.27-1.45zM20.5 17.65c-.58 1.34-1.27 2.66-2.34 3.96-.93 1.13-2.08 2.53-3.5 2.55-1.4.02-1.86-.82-3.46-.82-1.6 0-2.1.8-3.42.84-1.37.04-2.42-1.22-3.36-2.35-1.93-2.32-3.4-6.55-1.42-9.4 1.04-1.48 2.85-2.4 4.85-2.43 1.39-.02 2.7.93 3.43.93.73 0 2.34-1.15 3.95-.98.68.03 2.6.27 3.83 2.05-.1.06-2.29 1.34-2.26 4.0.03 3.1 2.7 4.14 2.73 4.15z" />
    </svg>
    <span class="lf">
      <span class="pre">Coming to the</span>
      <span class="post">App Store{store.expectedRelease ? ` · ${store.expectedRelease}` : ''}</span>
    </span>
  </span>
)}

<style>
  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px 10px 12px;
    border-radius: 10px;
    font-family: var(--font-sans);
    transition: transform 160ms ease, background 160ms ease;
  }
  .store-badge.live {
    background: var(--ink-primary);
    color: var(--bg);
  }
  .store-badge.live:hover {
    transform: translateY(-1px);
    color: var(--bg);
  }
  .store-badge.coming-soon {
    background: transparent;
    color: var(--ink-secondary);
    border: 1px dashed var(--rule-strong);
  }
  .apple { width: 22px; height: 22px; }
  .apple.muted { opacity: 0.7; }
  .lf { display: flex; flex-direction: column; line-height: 1.1; gap: 2px; text-align: left; }
  .pre {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .post {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
</style>
