---
/**
 * AppCard — home-grid card for a single app.
 * Featured size shows the full body; standard is a tighter 2-up.
 */
import type { AppEntry } from '@data/apps';
import { Image } from 'astro:assets';

interface Props {
  app: AppEntry;
  variant?: 'featured' | 'standard';
}

const { app, variant = 'standard' } = Astro.props;
const featured = variant === 'featured';
---

<a
  class:list={['app-card', { featured }]}
  href={`/apps/${app.slug}`}
  aria-label={`${app.name} — ${app.tagline}`}
>
  <div class="mono trail-no">
    Trail · {app.trailNumber} — {app.primaryCategory}
  </div>

  <div class="head">
    <div class="icon">
      <img src={app.icon} alt={`${app.name} app icon`} width={featured ? 96 : 76} height={featured ? 96 : 76} loading="lazy" />
    </div>
    <div class="head-text">
      <h3 class="name">{app.name}</h3>
      <p class="tag">{app.tagline}</p>
    </div>
  </div>

  {featured && <p class="body">{app.cardBlurb}</p>}

  <div class="foot">
    <div class="chips">
      {app.categories.slice(0, 3).map((c) => <span class="chip">{c}</span>)}
    </div>
    <span class="more mono">View trail →</span>
  </div>
</a>

<style>
  .app-card {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    border-radius: 18px;
    padding: clamp(22px, 2.4vw, 32px);
    color: var(--ink-primary);
    display: flex;
    flex-direction: column;
    gap: 18px;
    transition:
      transform 280ms var(--ease-out, cubic-bezier(0.2, 0.8, 0.25, 1)),
      border-color 280ms ease,
      box-shadow 280ms ease,
      background 280ms ease;
    box-shadow: var(--shadow-card);
    position: relative;
    overflow: hidden;
  }
  .app-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--ink-primary) 40%, var(--rule));
    box-shadow: var(--shadow-card-hover);
    color: var(--ink-primary);
  }
  .app-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }
  .app-card.featured { padding: clamp(28px, 2.8vw, 40px); }

  .trail-no { color: var(--ink-muted); }

  .head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: center;
  }
  .app-card.featured .head { gap: 22px; }
  .icon {
    width: 76px; height: 76px;
    border-radius: 18px;
    overflow: hidden;
    background: var(--paper);
    box-shadow: 0 1px 0 rgba(0,0,0,0.06), 0 12px 22px -16px rgba(28, 42, 32, 0.3);
    flex-shrink: 0;
  }
  .app-card.featured .icon { width: 96px; height: 96px; border-radius: 22px; }
  .icon img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .name {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(22px, 2.2vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .app-card.featured .name { font-size: clamp(28px, 2.8vw, 36px); }
  .tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 19px);
    color: var(--ink-secondary);
    margin: 4px 0 0 0;
    line-height: 1.3;
  }

  .body {
    font-size: 15.5px;
    color: var(--ink-secondary);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
  }

  .foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--rule);
  }
  .chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .more {
    color: var(--ink-muted);
    transition: color 160ms ease, transform 160ms ease;
  }
  .app-card:hover .more {
    color: var(--accent);
    transform: translateX(2px);
  }
</style>
