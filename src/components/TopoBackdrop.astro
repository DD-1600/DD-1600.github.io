---
/**
 * TopoBackdrop — decorative concentric topo lines + one dashed trail in rescue-orange.
 * Renders behind the hero. Drives the parallax scroll effect (handled by Hero).
 */
interface Props {
  id?: string;
  /** Density: how many primary lines (default 10). */
  lines?: number;
}
const { id = 'topo', lines = 10 } = Astro.props;
---

<div class="topo" id={id} aria-hidden="true">
  <svg viewBox="0 0 1200 700" preserveAspectRatio="none">
    {/* Primary topo lines — slightly varied curves */}
    <path d="M0 540 C 200 470, 380 530, 580 480 S 980 420, 1200 460" />
    <path d="M0 580 C 220 510, 400 580, 620 520 S 1000 470, 1200 510" />
    <path d="M0 620 C 240 560, 420 630, 660 570 S 1020 520, 1200 560" />
    <path d="M0 470 C 180 410, 340 460, 520 410 S 920 360, 1200 400" />
    <path d="M0 410 C 160 350, 320 400, 480 350 S 880 300, 1200 340" />
    <path d="M0 360 C 140 300, 300 340, 460 290 S 860 250, 1200 290" />
    <path d="M0 305 C 130 250, 280 290, 440 240 S 840 200, 1200 240" />
    <path d="M0 250 C 120 210, 260 240, 420 200 S 820 160, 1200 200" />
    <path d="M0 195 C 110 160, 240 190, 400 160 S 800 130, 1200 165" />
    <path d="M0 150 C 100 120, 220 145, 380 120 S 780 95, 1200 130" />
    {/* Dashed trail in rescue orange — the visible "path" through the topo */}
    <path
      class="trail"
      d="M120 660 C 280 540, 420 600, 560 480 C 700 360, 880 400, 1080 280"
    />
    {/* Trail markers */}
    <circle cx="280" cy="540" r="3" class="marker" />
    <circle cx="560" cy="480" r="3" class="marker" />
    <circle cx="880" cy="400" r="3" class="marker" />
  </svg>
</div>

<style>
  .topo {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.18;
    will-change: transform;
  }
  .topo svg { width: 100%; height: 100%; display: block; }
  .topo path {
    fill: none;
    stroke: var(--bone);
    stroke-width: 1.1;
    vector-effect: non-scaling-stroke;
  }
  .topo .trail {
    stroke: var(--accent);
    stroke-dasharray: 2 6;
    opacity: 0.85;
  }
  .topo .marker { fill: var(--accent); }
</style>
