---
/**
 * ThemeToggle — light/dark switch. The initial theme is set BEFORE this component
 * renders (see BaseLayout's inline boot script), so this only handles user clicks.
 */
---

<button class="theme-toggle" id="theme-toggle" aria-label="Toggle color theme">
  <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
  <span class="lbl" id="theme-label">Theme</span>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink-primary);
    padding: 7px 12px;
    border-radius: 999px;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: border-color 160ms ease, color 160ms ease;
  }
  .theme-toggle:hover { border-color: var(--ink-primary); color: var(--accent); }
  .icon {
    width: 14px;
    height: 14px;
    display: none;
  }
  :global([data-theme="light"]) .icon-moon { display: block; }
  :global([data-theme="dark"])  .icon-sun  { display: block; }
</style>

<script>
  (function () {
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    const lbl = document.getElementById('theme-label');
    if (!btn || !lbl) return;

    function refreshLabel() {
      const t = root.dataset.theme === 'dark' ? 'dark' : 'light';
      lbl.textContent = t === 'dark' ? 'Dark' : 'Light';
    }
    refreshLabel();

    btn.addEventListener('click', () => {
      const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try { localStorage.setItem('northland-theme', next); } catch (_) {}
      refreshLabel();
    });

    // Follow OS preference IF the user hasn't manually chosen.
    try {
      const mq = window.matchMedia('(prefers-color-scheme: dark)');
      mq.addEventListener?.('change', (e) => {
        if (!localStorage.getItem('northland-theme')) {
          root.dataset.theme = e.matches ? 'dark' : 'light';
          refreshLabel();
        }
      });
    } catch (_) {}
  })();
</script>
