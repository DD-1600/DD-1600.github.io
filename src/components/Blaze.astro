---
/**
 * Blaze — the N-blaze studio mark. Uses the inline <symbol id="blaze"> from BaseLayout.
 * `size` is the rendered pixel size; `tone` is the rect fill color (the "blaze" body).
 */
interface Props {
  size?: number;
  tone?: 'forest' | 'ink' | 'rescue' | 'bone' | 'currentColor';
  /** Stroke color for the N strokes. */
  fg?: 'bone' | 'forest' | 'ink';
  class?: string;
}

const { size = 28, tone = 'currentColor', fg = 'bone', class: cls = '' } = Astro.props;

const toneVar = tone === 'currentColor' ? 'currentColor' : `var(--${tone})`;
const fgVar = `var(--${fg})`;
---

<svg
  class={`blaze ${cls}`}
  style={`width:${size}px; height:${size}px; color: ${toneVar}; --blaze-fg: ${fgVar};`}
  aria-hidden="true"
>
  <use href="#blaze" />
</svg>

<style>
  .blaze {
    display: inline-block;
    flex-shrink: 0;
  }
</style>
