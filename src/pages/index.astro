---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import Hero from '@components/Hero.astro';
import AppCard from '@components/AppCard.astro';
import { apps } from '@data/apps';

// Ordering — featured (top) → standard grid.
// Feature: Cairn (subscription anchor), Roost, Wagcast.
const featuredSlugs = ['cairn', 'the-roost', 'wagcast'];
const featured = featuredSlugs
  .map((s) => apps.find((a) => a.slug === s))
  .filter((a): a is NonNullable<typeof a> => Boolean(a));
const rest = apps.filter((a) => !featuredSlugs.includes(a.slug));
---

<BaseLayout
  title="Northland Studios"
  description="A small studio in the north woods of the internet. One person, many small apps — games, family software, productivity tools, weather, and faith."
>
  <Nav />
  <Hero />

  {/* ─────────── Featured trio — Cairn / Roost / Wagcast ─────────── */}
  <main id="main">
    <section class="section" id="trails">
      <div class="section-header">
        <div>
          <div class="mono label">§ The trails</div>
          <h2>Ten small apps,<br />made&nbsp;by&nbsp;one&nbsp;person.</h2>
        </div>
        <p class="lede">
          Every app keeps its own name and audience. The studio is the&nbsp;signage
          that&nbsp;wraps the&nbsp;whole&nbsp;park.
        </p>
      </div>

      <div class="featured-grid">
        {featured.map((app) => <AppCard app={app} variant="featured" />)}
      </div>

      <div class="rest-header">
        <div class="mono label">§ The rest of the park</div>
        <h3>Seven more trails open along the way.</h3>
      </div>

      <div class="rest-grid">
        {rest.map((app) => <AppCard app={app} variant="standard" />)}
      </div>
    </section>

    {/* ─────────── About strip ─────────── */}
    <section class="about" id="about">
      <div class="about-inner">
        <div class="about-head">
          <div class="mono label">§ About the park</div>
          <h3 class="about-title">
            One person makes<br />the&nbsp;trails. The signs all match. The trails do not.
          </h3>
        </div>
        <div class="about-body">
          <p>
            Northland Studios is a solo, family-driven app shop in the
            north woods of the internet. We make small things, made&nbsp;well —
            the kind of apps that feel handmade, not optimized. Calm utilities, niche
            games, family software that doesn't read your messages.
          </p>
          <p>
            The studio is the park. The apps are trails. We open new trails when
            we have something real to show, and we keep the old ones&nbsp;walkable.
          </p>
          <p class="signoff">
            Open all&nbsp;seasons. Publishing&nbsp;apps&nbsp;quarterly. Built&nbsp;by&nbsp;hand.
          </p>
          <p class="contact-cta">
            <a class="cta" href="/contact">
              <span>Get in touch</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 2vw, 28px);
    margin-bottom: clamp(60px, 8vh, 100px);
  }
  @media (min-width: 980px) {
    .featured-grid {
      grid-template-columns: 1fr 1fr;
      grid-auto-rows: 1fr;
    }
    /* Make Cairn (1st) full-width to anchor the row; Roost + Wagcast share row 2. */
    .featured-grid > :global(.app-card):first-child {
      grid-column: 1 / -1;
    }
  }

  .rest-header { margin-bottom: 36px; }
  .rest-header h3 {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.15;
    margin: 8px 0 0 0;
    color: var(--ink-primary);
  }
  .rest-header .label { color: var(--accent); }

  .rest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(18px, 2vw, 26px);
  }

  /* About */
  .about {
    background: var(--bg-soft);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .about-inner {
    max-width: var(--col-max);
    margin: 0 auto;
    padding: clamp(80px, 12vh, 130px) var(--pad-page);
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }
  .about-head .label { color: var(--accent); margin-bottom: 14px; }
  .about-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(28px, 3.4vw, 40px);
    line-height: 1.2;
    margin: 0;
    color: var(--ink-primary);
    font-weight: 400;
  }
  .about-body p {
    margin: 0 0 18px 0;
    color: var(--ink-secondary);
    font-size: 17px;
    line-height: 1.66;
    max-width: 60ch;
  }
  .about-body .signoff {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--ink-primary);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid var(--ink-primary);
    border-radius: 999px;
    color: var(--ink-primary);
    margin-top: 12px;
    transition: background 160ms ease, color 160ms ease, transform 160ms ease;
  }
  .cta:hover { background: var(--accent); color: var(--bone); border-color: var(--accent); transform: translateY(-1px); }
  .cta svg { width: 16px; height: 16px; }
  .contact-cta { margin: 28px 0 0 0; }

  @media (max-width: 880px) {
    .about-inner { grid-template-columns: 1fr; gap: 32px; }
  }
</style>

