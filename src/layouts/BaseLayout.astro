---
/**
 * BaseLayout — single HTML shell for every page.
 *
 * Theme handling: a tiny inline script runs in <head> BEFORE first paint to set
 * `data-theme` on <html>, which prevents the dreaded flash-of-wrong-theme.
 * Order of precedence:
 *   1. localStorage("northland-theme")
 *   2. prefers-color-scheme
 *   3. default to "light"
 */
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Used as the OG image and Twitter card image. Defaults to /og-image.png. */
  ogImage?: string;
  /** Override the canonical URL (defaults to the current page). */
  canonical?: string;
  /** Class added to <body> — used for page-specific overrides. */
  bodyClass?: string;
}

const {
  title,
  description = 'A small studio in the north woods of the internet. One person, many small apps.',
  ogImage = '/og-image.png',
  canonical,
  bodyClass = '',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? (`${siteUrl}${Astro.url.pathname}`.replace(/\/$/, '') || siteUrl);
const fullTitle = title.includes('Northland') ? title : `${title} — Northland Studios`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {/* Theme color follows the brand — Forest for dark, Bone for light. */}
    <meta name="theme-color" content="#F1EDE4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1C2A20" media="(prefers-color-scheme: dark)" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content="Northland Studios" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    {/* Favicons — the N-blaze in SVG, falls back to PNG */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Fonts — Google Fonts hosting. Preconnect + display=swap for fast first paint. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap"
    />

    {/* RSS for future Field Notes blog */}
    <link rel="alternate" type="application/rss+xml" title="Northland Studios — Field Notes" href="/rss.xml" />

    {/* Theme bootstrap — runs before paint to avoid theme flash */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('northland-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>

  <body class={bodyClass}>
    <a href="#main" class="skip">Skip to content</a>

    {/* Inline N-blaze symbol — referenced via <use href="#blaze"> anywhere on the page */}
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <symbol id="blaze" viewBox="0 0 100 100">
          <rect x="6" y="6" width="88" height="88" rx="11" fill="currentColor" />
          <g fill="none" stroke="var(--blaze-fg, #F1EDE4)" stroke-width="11" stroke-linecap="square">
            <line x1="29" y1="22" x2="29" y2="78" />
            <line x1="71" y1="22" x2="71" y2="78" />
            <line x1="29" y1="22" x2="71" y2="78" />
          </g>
          <circle cx="56" cy="36" r="2.4" fill="currentColor" />
          <circle cx="64" cy="36" r="2.4" fill="currentColor" />
        </symbol>
      </defs>
    </svg>

    <slot />
  </body>
</html>
